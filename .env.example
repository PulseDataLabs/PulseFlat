# PulseFlat Environment Variables Config Example
# Copy this file to '.env' and fill in your values.

# S&P Global Scraper
# (Optional: if not provided, the scraper will extract the public key dynamically from the website)
SP_GLOBAL_API_KEY=your_sp_global_api_key_here

# ANBIMA Official API credentials
# (Optional: if not provided, scrapers will fall back to web scraping where supported)
ANBIMA_CLIENT_ID=your_anbima_client_id_here
ANBIMA_CLIENT_SECRET=your_anbima_client_secret_here
